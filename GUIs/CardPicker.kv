#:kivy 2.0
#:import Window kivy.core.window.Window

<CardPicker@Popup>:
    title: "Kies kaarten"
    size_hint: None, None
    size: dp(750), dp(350)
    auto_dismiss: False

    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(15)

        GridLayout:
            cols: 13
            rows: 4
            spacing: dp(5)
            size_hint_y: None
            height: dp(220)

            # --- RIJ 1: RUITEN ---
            Button:
                text: "A"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("A")
