# Consolidated Python .gitignore
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments
/.venv/
env/
venv/
.env

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.tox/
.coverage

# Editor directories
.vscode/
.idea/

# Misc
*.pyc
.DS_Store
.pdm-python
.mypy_cache/
.cache/
cython_debug/

# End of file

