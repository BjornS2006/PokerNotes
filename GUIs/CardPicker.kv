#:kivy 2.0
#:import Window kivy.core.window.Window

<CardPicker@Popup>:
    title: "Kies kaarten"
    size_hint: None, None
    size: dp(750), dp(350)
    auto_dismiss: False

    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(15)

        GridLayout:
            cols: 13
            rows: 4
            spacing: dp(5)
            size_hint_y: None
            height: dp(220)

            # --- RIJ 1: RUITEN (Diamonds) ---
            Button:
                id: diam_A
                text: "A"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("A")
            Button:
                id: diam_K
                text: "K"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("K")
            Button:
                id: diam_Q
                text: "Q"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("Q")
            Button:
                id: diam_J
                text: "J"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("J")
            Button:
                id: diam_T
                text: "T"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("T")
            Button:
                id: diam_9
                text: "9"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("9")
            Button:
                id: diam_8
                text: "8"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("8")
            Button:
                id: diam_7
                text: "7"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("7")
            Button:
                id: diam_6
                text: "6"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("6")
            Button:
                id: diam_5
                text: "5"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("5")
            Button:
                id: diam_4
                text: "4"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("4")
            Button:
                id: diam_3
                text: "3"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("3")
            Button:
                id: diam_2
                text: "2"
                background_color: 0.2, 0.4, 1, 1
                on_release: root.select_card("2")

            # --- RIJ 2: SCHOPPEN (Spades) ---
            Button:
                id: spad_A
                text: "A"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("A")
            Button:
                id: spad_K
                text: "K"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("K")
            Button:
                id: spad_Q
                text: "Q"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("Q")
            Button:
                id: spad_J
                text: "J"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("J")
            Button:
                id: spad_T
                text: "T"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("T")
            Button:
                id: spad_9
                text: "9"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("9")
            Button:
                id: spad_8
                text: "8"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("8")
            Button:
                id: spad_7
                text: "7"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("7")
            Button:
                id: spad_6
                text: "6"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("6")
            Button:
                id: spad_5
                text: "5"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("5")
            Button:
                id: spad_4
                text: "4"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("4")
            Button:
                id: spad_3
                text: "3"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("3")
            Button:
                id: spad_2
                text: "2"
                background_color: 0.1, 0.1, 0.1, 1
                on_release: root.select_card("2")

            # --- RIJ 3: HARTEN (Hearts) ---
            Button:
                id: heart_A
                text: "A"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("A")
            Button:
                id: heart_K
                text: "K"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("K")
            Button:
                id: heart_Q
                text: "Q"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("Q")
            Button:
                id: heart_J
                text: "J"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("J")
            Button:
                id: heart_T
                text: "T"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("T")
            Button:
                id: heart_9
                text: "9"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("9")
            Button:
                id: heart_8
                text: "8"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("8")
            Button:
                id: heart_7
                text: "7"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("7")
            Button:
                id: heart_6
                text: "6"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("6")
            Button:
                id: heart_5
                text: "5"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("5")
            Button:
                id: heart_4
                text: "4"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("4")
            Button:
                id: heart_3
                text: "3"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("3")
            Button:
                id: heart_2
                text: "2"
                background_color: 1, 0.2, 0.2, 1
                on_release: root.select_card("2")

            # --- RIJ 4: KLAVEREN (Clubs) ---
            Button:
                id: club_A
                text: "A"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("A")
            Button:
                id: club_K
                text: "K"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("K")
            Button:
                id: club_Q
                text: "Q"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("Q")
            Button:
                id: club_J
                text: "J"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("J")
            Button:
                id: club_T
                text: "T"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("T")
            Button:
                id: club_9
                text: "9"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("9")
            Button:
                id: club_8
                text: "8"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("8")
            Button:
                id: club_7
                text: "7"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("7")
            Button:
                id: club_6
                text: "6"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("6")
            Button:
                id: club_5
                text: "5"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("5")
            Button:
                id: club_4
                text: "4"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("4")
            Button:
                id: club_3
                text: "3"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("3")
            Button:
                id: club_2
                text: "2"
                background_color: 0.2, 1, 0.2, 1
                on_release: root.select_card("2")

        HoverButton:
            id: close_btn
            text: "Sluiten"
            size_hint_y: None
            height: dp(40)
            on_release: 
                root.dismiss()
                self.scale=1
            on_press:
                self.scale=0.97
            scale: 1

            canvas.before:
                PushMatrix
                Scale:
                    origin: self.center
                    x: self.scale
                    y: self.scale
                Color:
                    rgba: (0.1, 0.1, 0.1, 1) if self.hovered else (0, 0, 0, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]
                PopMatrix
            on_hovered:
                Window.set_system_cursor("hand" if self.hovered else "arrow")

            
            
                
                    