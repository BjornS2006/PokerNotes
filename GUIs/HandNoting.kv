#:kivy 2.0.0
#:import Window kivy.core.window.Window

AnchorLayout:
    anchor_x: 'left'
    anchor_y: 'center'

    canvas.before:
        Color:
            rgba: .2, .2, .2, 1
        Rectangle:
            pos: self.pos
            size: self.size

    ScrollView:
        size_hint: None, None
        width: dp(400)
        height: min(root.height, dp(750))

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: dp(16)
            spacing: dp(12)

            # ── Top bar ──────────────────────────────────────────────
            BoxLayout:
                size_hint_y: None
                height: dp(44)
                spacing: dp(8)

                HoverButton:
                    text: '< Terug'
                    size_hint: None, None
                    width: dp(90)
                    height: dp(34)
                    pos_hint: {'center_y': 0.5}
                    background_normal: ''
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1
                    font_size: 14
                    scale: 1
                    canvas.before:
                        PushMatrix
                        Scale:
                            origin: self.center
                            x: self.scale
                            y: self.scale
                        Color:
                            rgba: (0.15, 0.15, 0.15, 1) if self.hovered else (0, 0, 0, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6]
                        PopMatrix
                    on_press: self.scale = 0.97
                    on_release: self.scale = 1
                    on_hovered: Window.set_system_cursor("hand" if self.hovered else "arrow")

                Label:
                    text: 'Hand noteren'
                    color: 1, 1, 1, 1
                    font_size: 22
                    bold: True
                    halign: 'center'
                    valign: 'middle'

            # ── H Positie ────────────────────────────────────────────
            BoxLayout:
                size_hint_y: None
                height: dp(36)
                spacing: dp(10)

                Label:
                    text: 'H Positie:'
                    color: 1, 1, 1, 1
                    font_size: 16
                    bold: True
                    size_hint_x: None
                    width: dp(100)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

                TextInput:
                    id: hPositieInput
                    size_hint_x: None
                    width: dp(100)
                    height: dp(32)
                    multiline: False
                    background_color: .75, .75, .75, 1
                    foreground_color: 0, 0, 0, 1
                    font_size: 14
                    padding: [6, 6]

            # ── Position buttons row 1 (EP LJ HJ CO BU SB BB) ────────
            BoxLayout:
                size_hint_y: None
                height: dp(38)
                spacing: dp(6)

                HoverButton:
                    text: 'EP'
