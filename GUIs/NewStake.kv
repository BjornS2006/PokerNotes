#:kivy 2.0
#:import Window kivy.core.window.Window
<AddStakeScreen>:
    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'center'


        canvas.before:
            Color:
                rgba: .2, .2, .2, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: 'vertical'
            padding: 20
            spacing: 15
            size_hint: None, None
            width: dp(300)

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: dp(40)

                HoverButton:
                    id: BackButton
                    text: "< Terug"
                    size_hint_x: None
                    width: dp(80)
                    background_normal: ''
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1
                    on_press:
                        self.scale=0.97
                    on_release:
                        self.scale=1
                        #terug naar home, animatie gaat naar rechts
                        root.manager.transition.direction = 'right'
                        root.manager.current = 'home'
                    
                    scale: 1

                    canvas.before:
                        PushMatrix
                        Scale:
                            origin: self.center
                            x: self.scale
                            y: self.scale
                        Color:
                            rgba: (0.1, 0.1, 0.1, 1) if self.hovered else (0, 0, 0, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10]
                        PopMatrix
                    on_hovered:
                        Window.set_system_cursor("hand" if self.hovered else "arrow")

                Widget:   # duwt de titel naar het midden

                Label:
                    id: title
                    text: 'Nieuwe Stake'
                    font_size: 30
                    size_hint_x: None
                    width: dp(140)

            BoxLayout:
                orientation: 'horizontal'
                spacing: 10
                size_hint_y: None
                height: dp(40)
                Label:
                    text: 'Small Blind:'
                    font_size: 22
                TextInput:
                    id: sbInput
                    multiline: False
                    size_hint_x: 1
                    input_filter: 'float'
                    height: dp(30)
                    size_hint_y: None
                    background_normal: ''
                    background_active: ''
                    background_color: (1, 1, 1, 1) if self.focus else (.30, .30, .30, 1)
                    foreground_color: 1, 1, 1, 1

            BoxLayout:
                orientation: 'horizontal'
                spacing: 10
                size_hint_y: None
                height: dp(40)
                Label:
                    text: 'Big Blind:'
                    font_size: 22
                TextInput:
                    id: bbInput
                    multiline: False
                    size_hint_x: 1
                    input_filter: 'float'
                    height: dp(30)
                    size_hint_y: None
                    background_normal: ''
                    background_active: ''
                    background_color: (1, 1, 1, 1) if self.focus else (.30, .30, .30, 1)
                    foreground_color: 1, 1, 1, 1
                        
            BoxLayout:
                size_hint_y: None
                height: dp(60)
                padding: 0
                spacing: 0
                orientation: 'horizontal'

                Widget:   # lege ruimte links

                HoverButton:
                    id: addStake
                    text: 'Toevoegen'
                    size_hint: None, None
                    width: dp(150)
                    height: dp(50)
                    background_normal: ''
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1

                    on_press:
                        self.scale=0.97
                    on_release:
                        self.scale=1
                    
                    scale: 1

                    canvas.before:
                        PushMatrix
                        Scale:
                            origin: self.center
                            x: self.scale
                            y: self.scale
                        Color:
                            rgba: (0.1, 0.1, 0.1, 1) if self.hovered else (0, 0, 0, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10]
                        PopMatrix
                    on_hovered:
                        Window.set_system_cursor("hand" if self.hovered else "arrow")

                Widget:   # lege ruimte rechts

