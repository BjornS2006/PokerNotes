#:kivy 2.0.0
#:import Window kivy.core.window.Window
AnchorLayout:
    anchor_x:'center'
    anchor_y:'center'

    canvas.before:
        Color:
            rgba: .2, .2, .2, 1
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation:'vertical'
        spacing: 15
        size_hint: None, None
        width: dp(400)

        Label:
            id:title
            text: 'Welkom bij PokerNotes!'
            size_hint_y: None
            height: dp(40)
            font_size: 40

        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: 0
            spacing: 0
            orientation: 'horizontal'

            Widget:
        
            HoverButton:
                text:'Handen noteren'
                id: noterenButton
                size_hint: None, None
                width: dp(200)
                height: dp(60)
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1

                on_press:
                    self.scale=0.97
                on_release:
                    self.scale=1
                    
                scale: 1

                canvas.before:
                    PushMatrix
                    Scale:
                        origin: self.center
                        x: self.scale
                        y: self.scale
                    Color:
                        rgba: (0.1, 0.1, 0.1, 1) if self.hovered else (0, 0, 0, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                    PopMatrix
                on_hovered:
                    Window.set_system_cursor("hand" if self.hovered else "arrow")

            Widget: 
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: 0
            spacing: 0
            orientation: 'horizontal'

            Widget:

            HoverButton:
                text:'Verleden handen'
                id: PastHandsButton
                size_hint: None, None
                width: dp(200)
                height: dp(60)
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1

                on_press:
                    self.scale=0.97
                on_release:
                    self.scale=1
                    
                scale: 1

                canvas.before:
                    PushMatrix
                    Scale:
                        origin: self.center
                        x: self.scale
                        y: self.scale
                    Color:
                        rgba: (0.1, 0.1, 0.1, 1) if self.hovered else (0, 0, 0, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                    PopMatrix
                on_hovered:
                    Window.set_system_cursor("hand" if self.hovered else "arrow")

            Widget: 

        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: 0
            spacing: 0
            orientation: 'horizontal'

            Widget:

            HoverButton:
                text:'Stake toevoegen'
                id: AddStakeButton
                size_hint: None, None
                width: dp(200)
                height: dp(60)
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1

                on_press:
                    self.scale=0.97
                on_release:
                    self.scale=1
                    
                scale: 1

                canvas.before:
                    PushMatrix
                    Scale:
                        origin: self.center
                        x: self.scale
                        y: self.scale
                    Color:
                        rgba: (0.1, 0.1, 0.1, 1) if self.hovered else (0, 0, 0, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                    PopMatrix
                on_hovered:
                    Window.set_system_cursor("hand" if self.hovered else "arrow")
            
            Widget: 

